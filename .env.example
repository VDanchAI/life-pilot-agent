# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Deepgram API key for voice transcription
DEEPGRAM_API_KEY=

# Todoist API key for task management
TODOIST_API_KEY=

# Path to Obsidian vault directory
VAULT_PATH=./vault

# JSON array of Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_USER_IDS=[123456789]

# Claude CLI timeout in seconds (default: 1200)
CLAUDE_TIMEOUT=1200

# Deepgram transcription language (default: ru)
TRANSCRIPTION_LANGUAGE=ru

# Claude model for Coach Mode — use a more capable model for better quality
COACH_MODEL=claude-opus-4-5-20251101

# Path to Google OAuth token (for Google Calendar integration)
GOOGLE_TOKEN_PATH=~/life-pilot/token.json
