[Unit]
Description=d-brain Weekly Digest
After=network.target

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/projects/agent-second-brain
ExecStart=/home/ubuntu/.local/bin/uv run python scripts/weekly.py
EnvironmentFile=/home/ubuntu/projects/agent-second-brain/.env
StandardOutput=journal
StandardError=journal
